# apps/api/.env.example
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.
# Safe defaults (no secrets) are in .env and are committed.

# ============================================================
# REQUIRED — API will refuse to start if any of these are missing
# ============================================================

# Supabase project URL (Supabase dashboard > Settings > API)
SUPABASE_URL=https://your-project.supabase.co

# Service role key — bypasses RLS, keep secret
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Postgres connection string with pgbouncer for Kysely
DATABASE_URL=postgresql://postgres.xxx:password@host:6543/postgres?pgbouncer=true

# Anthropic API key for Claude agent
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================
# OPTIONAL
# ============================================================

# HTTP port (default: 3001, set in .env)
# PORT=3001

# CORS allowed origin (default: http://localhost:3000, set in .env)
# Set to Vercel production URL in production
# CORS_ORIGIN=https://your-app.vercel.app

# Public URL for Telegram/WhatsApp webhook registration
# Use ngrok URL in dev, Railway URL in production
API_BASE_URL=https://your-tunnel.ngrok.io

# WhatsApp Cloud API webhook secret
WHATSAPP_APP_SECRET=your-webhook-secret
